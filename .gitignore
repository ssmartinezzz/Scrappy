# Logs
*.log
scraper/*.log
logs/

# Databases
scraper.db
scraper/scraper.db
*.db-journal

# Dependencies
frontend/node_modules/
_tools/node/node_modules/

# Build output
scraper/target/
scraper/scraper.jar

# Allure report output (generated by `mvn allure:report` / `allure:serve`;
# target/allure-results/ is already covered by scraper/target/ above)
/allure-report/
/.allure/
scraper/allure-report/
scraper/.allure/
# Vite build output (regenerated by `npm run build` in frontend/ before JAR packaging) — do not remove this entry
scraper/src/main/resources/static/

# ML-generated outputs
ml_output.json
ml_productos.json
precio_historico.json
scraper/ml_output.json
scraper/ml_productos.json
scraper/precio_historico.json
_models/
scraper/_models/

# Runtime-extracted copies of ml_pipeline.py (PythonRunner.java extracts from the JAR
# next to scraper.jar at startup) — the only source of truth lives in
# scraper/src/main/resources/ml/ml_pipeline.py
/ml_pipeline.py
scraper/ml_pipeline.py

# Vendored toolchain
_tools/

# Python bytecode cache
__pycache__/
*.pyc

# IDE
.idea/
.vscode/

# OS artifacts
Thumbs.db
.DS_Store

# Legacy SDD store (intentionally not tracked)
.atl/

# Local machine config
.claude/settings.local.json
identidad/
