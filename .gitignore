# Logs
*.log
scraper/*.log
logs/

# Databases
scraper.db
scraper/scraper.db
*.db-journal
*.db-shm
*.db-wal

# Dependencies
frontend/node_modules/
_tools/node/node_modules/

# Build output
scraper/target/
scraper/scraper.jar

# Allure report output (generated by `mvn allure:report` / `allure:serve`;
# target/allure-results/ is already covered by scraper/target/ above)
/allure-report/
/.allure/
scraper/allure-report/
scraper/.allure/
# Vite build output — the frontend is now its own service (design D6) and emits
# to frontend/dist/. The old scraper/.../static/ path is kept ignored only to
# swallow any stale artifacts from before the service split.
frontend/dist/
scraper/src/main/resources/static/

# ML-generated outputs
ml_output.json
ml_productos.json
precio_historico.json
scraper/ml_output.json
scraper/ml_productos.json
scraper/precio_historico.json
_models/
scraper/_models/

# Runtime-extracted copies of the ML scripts (PythonRunner.java extracts them from
# the JAR next to scraper.jar at startup) — the only source of truth lives in
# scraper/src/main/resources/ml/
/ml_pipeline.py
scraper/ml_pipeline.py
/ml_train.py
scraper/ml_train.py
/ml_embeddings.py
scraper/ml_embeddings.py

# Vendored toolchain
_tools/

# Python bytecode cache
__pycache__/
*.pyc

# IDE
.idea/
.vscode/

# OS artifacts
Thumbs.db
.DS_Store

# Legacy SDD store (intentionally not tracked)
.atl/

# Local machine config
.claude/settings.local.json
identidad/

# decouple-services-postgres, Batch 4: installer-generated env (DATABASE_URL,
# SCRAPER_MODELS_ROOT, CORS/VITE origins, ports) — never committed, sourced by
# the launcher at process-start time only.
.env
frontend/.env

# Portable Postgres data directory (provisioned by the installer under
# _tools/pgsql, already covered by the _tools/ rule above, but the runtime
# datadir can also be created outside _tools/ during local dev/testing)
pgdata/
_pgdata/
