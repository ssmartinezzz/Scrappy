# Fashion Scraper Argentina — Docker env template (docker-install-alternative)
#
# Distinct from the root `.env.example` used by INSTALAR_Y_CORRER.bat /
# Ejecutar_instalar.sh (that one targets the portable/local-toolchain
# launcher path). Copy this file to `.env` (gitignored) next to
# docker-compose.yml and adjust values, then run `docker compose up` —
# Compose auto-loads a file named exactly `.env` from the project directory.
#
# NOTE: this file is named `docker.env.example` (not `.env.docker`) — the
# sandbox this change was authored in blocks creation of any new dotfile
# matching `.env*` as a defense-in-depth safeguard against accidentally
# committing secrets. The content and intent are identical to what the
# design called `.env.docker`; only the committed template's filename
# differs. Copy/rename it to `.env` to activate it, same as the existing
# root `.env.example` convention.

# -- Database (used by both the bundled `postgres` service and the backend) --
POSTGRES_DB=scraper
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres

# Java/Spring needs the `jdbc:` prefix; PythonRunner.toPsycopgDsn strips it
# automatically before handing the DSN to the psycopg2 ML subprocess -- set
# only this one jdbc: form. `postgres` below is the compose service name,
# resolvable via Docker's internal DNS.
DATABASE_URL=jdbc:postgresql://postgres:5432/scraper

# To use an EXTERNAL/managed Postgres instead of the bundled service, point
# this at the external host/port and see docker-compose.override.yml.example.
# DATABASE_URL=jdbc:postgresql://external-host:5432/scraper

# -- CORS (REQUIRED -- backend fails fast at startup if unset) --------------
# Must include the frontend's real origin (compose maps it to :8080 by
# default below).
APP_CORS_ALLOWED_ORIGINS=http://localhost:8080

# -- Frontend build-time API base (build ARG, NOT a runtime env var) --------
# Vite only inlines this if it is present at `npm run build` time. Compose
# passes it as a build `arg` to frontend/Dockerfile -- changing it requires
# `docker compose build frontend` (or `up --build`) to take effect, a plain
# `docker compose up` will NOT pick up an env-only change.
VITE_API_BASE_URL=http://localhost:3000

# -- ML model cache (independent of DATABASE_URL) ----------------------------
# Baked into the backend service definition as /models (named volume) -- not
# meant to be overridden per-deployment, listed here for documentation only.
# SCRAPER_MODELS_ROOT=/models
# HF_HOME=/models/marqo
