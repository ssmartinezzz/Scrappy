# decouple-services-postgres, Batch 3 (task 3.5): API base URL for the
# frontend's fetch client (frontend/src/api.js). Leave unset in local dev to
# keep using the Vite dev-server proxy (vite.config.js forwards /api to
# http://localhost:3000). Set to the backend's real origin for any deployment
# where the frontend is served from a different origin than the API
# (matches the backend's APP_CORS_ALLOWED_ORIGINS allow-list, design D6).
# VITE_API_BASE_URL=http://localhost:3000
