# Fashion Scraper Argentina — root env template (decouple-services-postgres,
# scoped correction closing verify-report CRITICAL-1). Copy to `.env` (already
# gitignored) and fill in real values, OR let INSTALAR_Y_CORRER.bat /
# Ejecutar_instalar.sh generate `.env` for you from a portable local Postgres.
#
# The backend (Spring Boot) and Python ML subprocess both read these directly
# from the process environment — never from an in-app `.env` parser. The
# launcher scripts source this file and export each var into the process
# environment of every service they start.
#
# Frontend note: `VITE_API_BASE_URL` is a SEPARATE var, documented in its own
# template at frontend/.env.example (Vite only reads vars from frontend/.env*,
# not from this root file) — not duplicated here.

# ── Database (REQUIRED — backend fails fast at startup if unset) ───────────
# Java/Spring needs the `jdbc:` prefix. Python (psycopg2, via
# PythonRunner.toPsycopgDsn) does NOT understand `jdbc:` — the Java backend
# automatically strips it before passing DATABASE_URL to the Python
# subprocess, so set this ONE value in the `jdbc:` form; nothing else to do.
DATABASE_URL=jdbc:postgresql://localhost:5432/scraper

# Postgres role used by both Java (HikariCP) and Python (psycopg2).
DATABASE_USERNAME=postgres

# May be an EMPTY string for local trust-auth Postgres (e.g. the installer's
# portable _tools/pgsql, provisioned with `initdb -A trust`) — an explicit
# empty value is NOT treated as "missing" by the backend's fail-fast guard,
# only a fully unset var is.
DATABASE_PASSWORD=postgres

# ── CORS (REQUIRED — backend fails fast at startup if unset) ───────────────
# Comma-separated list of allowed frontend origins, e.g.
# https://app.example.com,https://admin.example.com
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173

# ── ML model cache (REQUIRED by the ML subprocess; independent of DATABASE_URL) ──
# Root directory for the zero-shot vision model cache (HF_HOME derives from
# <SCRAPER_MODELS_ROOT>/marqo). Resolved independently of the DB location —
# works the same whether Postgres is local or remote.
SCRAPER_MODELS_ROOT=./scraper/_models

# ── Optional ─────────────────────────────────────────────────────────────
# Backend is API-only; unset by default (no-op). If set, the backend opens
# this URL in the local browser once Tomcat is ready — point it at the
# frontend's real origin if you want that convenience.
# APP_OPEN_URL=http://localhost:3000

# Explicitly opt into local development fallbacks (application-dev.properties):
# when set to `dev`, the backend no longer requires DATABASE_URL/USERNAME/
# PASSWORD/APP_CORS_ALLOWED_ORIGINS above — it falls back to
# jdbc:postgresql://localhost:5432/scraper + postgres/postgres +
# http://localhost:5173. Leave unset (default profile) for a real fail-fast
# start, including the installer's generated `.env` which always sets every
# required var explicitly and never relies on this profile.
# SPRING_PROFILES_ACTIVE=dev

# Rolling log directory override (backend). Defaults to `logs/` next to the
# jar when unset.
# LOG_DIR=./scraper/logs
